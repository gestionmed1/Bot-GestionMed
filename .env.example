# ── Copia este archivo como .env y rellena los valores reales ──────────────

# Token de acceso de la página de Facebook (con permisos instagram_manage_messages)
# Obténlo en: Meta Developer > Tu App > Instagram > Generar Token
PAGE_ACCESS_TOKEN=EAAxxxxxxxxxxxxxx

# Token de verificación del webhook (tú lo inventas, ponlo también en Meta Developer)
WEBHOOK_VERIFY_TOKEN=gestionmed_webhook_2025

# ID de tu página de Facebook vinculada a Instagram Business
# Obténlo en: facebook.com/YOUR_PAGE/about o con la API
PAGE_ID=123456789012345

# URL para dejar reseña en Google
# Obténla en: Google Business Profile > Pedir reseñas > Copia el enlace corto
GOOGLE_REVIEW_URL=https://g.page/r/XXXXXXXXXXXXXXXX/review

# Configuración del servidor
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
